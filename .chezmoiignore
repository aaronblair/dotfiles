{{- $profile := get . "profile" -}}
{{- if eq $profile "" -}}
{{- $profile = env "CHEZMOI_PROFILE" -}}
{{- if eq $profile "" -}}
{{- if eq .chezmoi.os "darwin" -}}
{{- $profile = "macos" -}}
{{- else if eq .chezmoi.os "linux" -}}
{{- $profile = "server" -}}
{{- else -}}
{{- $profile = .chezmoi.os -}}
{{- end -}}
{{- end -}}
{{- end -}}
{{- $isMacos := eq $profile "macos" -}}
{{- $isServer := eq $profile "server" -}}
{{- $isDev := eq $profile "dev" -}}
{{- $isAi := eq $profile "ai" -}}
{{- $isLinux := or $isServer $isDev $isAi -}}
{{- $hasDisplay := $isMacos -}}
{{- $hasDisplayEnv := env "CHEZMOI_HAS_DISPLAY" -}}
{{- if or (eq $hasDisplayEnv "1") (eq $hasDisplayEnv "true") -}}
{{- $hasDisplay = true -}}
{{- else if or (eq $hasDisplayEnv "0") (eq $hasDisplayEnv "false") -}}
{{- $hasDisplay = false -}}
{{- end -}}
{{- $managesPersonalSSH := or $isMacos $isDev -}}
{{- $managesGh := or $isMacos $isDev -}}
{{- $managesOpencode := or $isMacos $isDev $isAi -}}

README.md
AGENTS.md
prd.md
.opencode/
.gitignore
Users/
Users/**

{{- if not $isMacos }}
# Darwin-only (skip on Linux)
Library/
run_once_*darwin*
{{- end }}

{{- if not $isLinux }}
# Linux-only
.zshenv
run_once_*linux*
{{- end }}

{{- if not $hasDisplay }}
# GUI apps not needed on non-display profiles.
.wezterm.lua
.config/ghostty
.config/ghostty/**
{{- end }}

{{- if not $managesPersonalSSH }}
.ssh
.ssh/**
{{- end }}

{{- if not $managesGh }}
.config/gh
.config/gh/**
{{- end }}

{{- if not $managesOpencode }}
.config/opencode
.config/opencode/**
{{- end }}
