{{- $profile := get . "profile" -}}
{{- if eq $profile "" -}}
{{- $profile = env "CHEZMOI_PROFILE" -}}
{{- if eq $profile "" -}}
{{- if eq .chezmoi.os "darwin" -}}
{{- $profile = "macos" -}}
{{- else if eq .chezmoi.os "linux" -}}
{{- $profile = "server" -}}
{{- else -}}
{{- $profile = .chezmoi.os -}}
{{- end -}}
{{- end -}}
{{- end -}}
{{- $isMacos := eq $profile "macos" -}}
{{- $isDev := eq $profile "dev" -}}
{{- $isAi := eq $profile "ai" -}}
{{- $managesPersonalSSH := or $isMacos $isDev -}}
{{- $managesGh := or $isMacos $isDev -}}
{{- $managesOpencode := or $isMacos $isDev $isAi -}}

{{- if not $managesPersonalSSH }}
.ssh/config
{{- end }}
{{- if not $managesGh }}
.config/gh/config.yml
.config/gh/hosts.yml
{{- end }}
{{- if not $managesOpencode }}
.config/opencode
{{- end }}
