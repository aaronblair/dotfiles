{{- includeTemplate ".chezmoitemplates/profile-guard.tmpl" . -}}
# Loaded by every zsh invocation; keep this file minimal and quiet.
local_env_dir="${XDG_CONFIG_HOME:-$HOME/.config}/env.d"
if [[ -d "$local_env_dir" ]]; then
  for local_env_file in "$local_env_dir"/*.zsh(N); do
    source "$local_env_file"
  done
  unset local_env_file
fi
unset local_env_dir

{{- if eq .chezmoi.os "linux" }}
# Debian/Ubuntu initialize completion globally unless this is set before /etc/zsh/zshrc.
skip_global_compinit=1

if [[ -n "${TERM:-}" && "${TERM:-}" != dumb && "${TERM:-}" != linux ]] \
  && (( ${+commands[infocmp]} )) \
  && ! infocmp "$TERM" > /dev/null 2>&1; then
  export TERM=xterm-256color
fi

path=("$HOME/.local/bin" $path)
{{- if or .is_dev .is_ai }}
export PNPM_HOME="${PNPM_HOME:-$HOME/.local/share/pnpm}"
path=("$PNPM_HOME" $path)
{{- end }}
{{- if .manages_opencode }}
path=("$HOME/.opencode/bin" $path)
{{- end }}
typeset -U path PATH
{{- end }}
