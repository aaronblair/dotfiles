{{- $profile := get . "profile" -}}
{{- if eq $profile "" -}}
{{- $profile = env "CHEZMOI_PROFILE" -}}
{{- if eq $profile "" -}}
{{- if eq .chezmoi.os "darwin" -}}
{{- $profile = "macos" -}}
{{- else if eq .chezmoi.os "linux" -}}
{{- $profile = "server" -}}
{{- else -}}
{{- $profile = .chezmoi.os -}}
{{- end -}}
{{- end -}}
{{- end -}}
{{- $isMacos := eq $profile "macos" -}}
{{- $isServer := eq $profile "server" -}}
{{- $isDev := eq $profile "dev" -}}
{{- $isAi := eq $profile "ai" -}}
{{- $profileValid := or $isMacos $isServer $isDev $isAi -}}
{{- $profileError := "" -}}
{{- if not $profileValid -}}
{{- $profileError = printf "invalid CHEZMOI_PROFILE %q" $profile -}}
{{- end -}}
{{- if or $isMacos $isDev $isAi -}}
#!/bin/sh
set -e

echo "[chezmoi] Initializing neovim..."

# Sync lazy.nvim plugins
nvim --headless "+Lazy! sync" +qa 2>/dev/null || true

# Install common treesitter parsers
nvim --headless "+TSInstall! lua bash json yaml markdown javascript typescript tsx python go dockerfile html css" +qa 2>/dev/null || true

echo "[chezmoi] Neovim initialization complete"
{{- end -}}
