{{- includeTemplate ".chezmoitemplates/profile-guard.tmpl" . -}}
{{- if .is_linux -}}
#!/bin/sh
set -eu

ZELLIJ_VERSION="0.44.3"
NODE_VERSION="22.21.1"
NODE_HOME="$HOME/.local/share/node"
PNPM_VERSION="11.6.0"
PNPM_HOME="${PNPM_HOME:-$HOME/.local/share/pnpm}"
PNPM_GLOBAL_DIR="${PNPM_GLOBAL_DIR:-$HOME/.local/share/pnpm/global}"
PATH="$HOME/.local/bin:$NODE_HOME/bin:$PNPM_HOME:$HOME/.opencode/bin:$PATH"

PROFILE="{{ .profile }}"

APT_SERVER_PACKAGES='{{ range .packages.linux.repo.apt.server }}{{ . }} {{ end }}'
APT_DEV_PACKAGES='{{ range .packages.linux.repo.apt.dev }}{{ . }} {{ end }}'
APT_AI_PACKAGES='{{ range .packages.linux.repo.apt.ai }}{{ . }} {{ end }}'
APK_SERVER_PACKAGES='{{ range .packages.linux.repo.apk.server }}{{ . }} {{ end }}'
APK_DEV_PACKAGES='{{ range .packages.linux.repo.apk.dev }}{{ . }} {{ end }}'
APK_AI_PACKAGES='{{ range .packages.linux.repo.apk.ai }}{{ . }} {{ end }}'
DEV_INSTALLERS='{{ range .packages.linux.install.dev }}{{ . }} {{ end }}'
AI_INSTALLERS='{{ range .packages.linux.install.ai }}{{ . }} {{ end }}'

echo "[chezmoi] Installing packages for Linux..."

# Determine if we need sudo
if [ "$(id -u)" -eq 0 ]; then
    SUDO=""
else
    SUDO="sudo"
fi

fetch_url() {
    if command -v curl > /dev/null 2>&1; then
        curl -fsSL "$1"
    else
        wget -qO- "$1"
    fi
}

repo_packages_for_profile() {
    server_packages="$1"
    dev_packages="$2"
    ai_packages="$3"

    case "$PROFILE" in
        server)
            printf '%s\n' "$server_packages"
            ;;
        dev)
            printf '%s %s\n' "$server_packages" "$dev_packages"
            ;;
        ai)
            printf '%s %s\n' "$server_packages" "$ai_packages"
            ;;
        *)
            echo "[chezmoi] Unsupported Linux profile: $PROFILE"
            exit 1
            ;;
    esac
}

installer_targets_for_profile() {
    case "$PROFILE" in
        dev)
            printf '%s\n' "$DEV_INSTALLERS"
            ;;
        ai)
            printf '%s\n' "$AI_INSTALLERS"
            ;;
        *)
            printf '\n'
            ;;
    esac
}

install_apt_packages() {
    packages="$1"
    available=""
    skipped=""

    $SUDO env DEBIAN_FRONTEND=noninteractive LANG=C.UTF-8 LC_ALL=C.UTF-8 apt-get update

    for pkg in $packages; do
        if apt-cache show "$pkg" > /dev/null 2>&1; then
            available="$available $pkg"
        else
            skipped="$skipped $pkg"
        fi
    done

    if [ -n "$available" ]; then
        # shellcheck disable=SC2086
        $SUDO env DEBIAN_FRONTEND=noninteractive LANG=C.UTF-8 LC_ALL=C.UTF-8 apt-get install -y $available
    fi

    if [ -n "$skipped" ]; then
        echo "[chezmoi] Skipping unavailable apt packages:$skipped"
    fi
}

install_apk_packages() {
    packages="$1"
    available=""
    skipped=""

    for pkg in $packages; do
        if apk search -qe "$pkg" > /dev/null 2>&1; then
            available="$available $pkg"
        else
            skipped="$skipped $pkg"
        fi
    done

    if [ -n "$available" ]; then
        # shellcheck disable=SC2086
        apk add --no-cache $available
    fi

    if [ -n "$skipped" ]; then
        echo "[chezmoi] Skipping unavailable apk packages:$skipped"
    fi
}

install_uv() {
    if command -v uv > /dev/null 2>&1; then
        return
    fi

    echo "[chezmoi] Installing uv..."
    fetch_url "https://astral.sh/uv/install.sh" | sh
}

install_node() {
    if command -v node > /dev/null 2>&1; then
        NODE_CURRENT_VERSION="$(node -v 2> /dev/null || true)"
        NODE_CURRENT_MAJOR="${NODE_CURRENT_VERSION#v}"
        NODE_CURRENT_MAJOR="${NODE_CURRENT_MAJOR%%.*}"
        if [ "${NODE_CURRENT_MAJOR:-0}" -ge 22 ] 2> /dev/null; then
            return
        fi
    fi

    echo "[chezmoi] Installing Node.js ${NODE_VERSION} to ~/.local/share/node..."

    case "$(uname -m)" in
        x86_64|amd64) NODE_ARCH="x64" ;;
        aarch64|arm64) NODE_ARCH="arm64" ;;
        *)
            echo "[chezmoi] Unsupported architecture for Node.js binary: $(uname -m)"
            exit 0
            ;;
    esac

    mkdir -p "$HOME/.local/share" "$HOME/.local/bin"
    NODE_TARBALL="node-v${NODE_VERSION}-linux-${NODE_ARCH}.tar.xz"
    NODE_TMPDIR="$(mktemp -d)"
    trap 'rm -rf "$NODE_TMPDIR"' EXIT HUP INT TERM

    fetch_url "https://nodejs.org/dist/v${NODE_VERSION}/${NODE_TARBALL}" > "$NODE_TMPDIR/$NODE_TARBALL"
    xz -dc "$NODE_TMPDIR/$NODE_TARBALL" | tar -xf - -C "$HOME/.local/share"
    ln -sfn "$HOME/.local/share/node-v${NODE_VERSION}-linux-${NODE_ARCH}" "$NODE_HOME"
    ln -sf "$NODE_HOME/bin/node" "$HOME/.local/bin/node"
    ln -sf "$NODE_HOME/bin/npm" "$HOME/.local/bin/npm"
    ln -sf "$NODE_HOME/bin/npx" "$HOME/.local/bin/npx"
    ln -sf "$NODE_HOME/bin/corepack" "$HOME/.local/bin/corepack"
    rm -rf "$NODE_TMPDIR"
    trap - EXIT HUP INT TERM
}

install_pnpm() {
    if command -v pnpm > /dev/null 2>&1 && pnpm --version > /dev/null 2>&1; then
        return
    fi

    echo "[chezmoi] Installing pnpm ${PNPM_VERSION} to ~/.local/share/pnpm-pkg..."

    case "$(uname -m)" in
        x86_64|amd64) PNPM_ARCH="x64" ;;
        aarch64|arm64) PNPM_ARCH="arm64" ;;
        *)
            echo "[chezmoi] Unsupported architecture for pnpm binary: $(uname -m)"
            exit 0
            ;;
    esac

    PNPM_PKG_DIR="$HOME/.local/share/pnpm-pkg"
    mkdir -p "$HOME/.local/bin" "$PNPM_PKG_DIR"
    PNPM_TMPDIR="$(mktemp -d)"
    trap 'rm -rf "$PNPM_TMPDIR"' EXIT HUP INT TERM
    fetch_url "https://github.com/pnpm/pnpm/releases/download/v${PNPM_VERSION}/pnpm-linux-${PNPM_ARCH}.tar.gz" > "$PNPM_TMPDIR/pnpm.tar.gz"
    tar -xzf "$PNPM_TMPDIR/pnpm.tar.gz" -C "$PNPM_PKG_DIR"
    chmod 0755 "$PNPM_PKG_DIR/pnpm"
    ln -sf "$PNPM_PKG_DIR/pnpm" "$HOME/.local/bin/pnpm"
    rm -rf "$PNPM_TMPDIR"
    trap - EXIT HUP INT TERM
    hash -r 2> /dev/null || true
}

install_kagi_ken_cli() {
    if command -v kagi-ken-cli > /dev/null 2>&1; then
        KAGI_KEN_CLI_BIN="$(command -v kagi-ken-cli)"
        case "$KAGI_KEN_CLI_BIN" in
            "$PNPM_HOME"/*)
                return
                ;;
        esac
    fi

    install_pnpm
    mkdir -p "$PNPM_HOME" "$PNPM_GLOBAL_DIR"

    echo "[chezmoi] Installing kagi-ken-cli with pnpm..."
    pnpm --config.global-bin-dir="$PNPM_HOME" \
        --config.global-dir="$PNPM_GLOBAL_DIR" \
        --config.block-exotic-subdeps=false \
        add --global "github:czottmann/kagi-ken-cli#44b44f2"
}

install_opencode() {
    if command -v opencode > /dev/null 2>&1; then
        return
    fi

    echo "[chezmoi] Installing OpenCode..."
    fetch_url "https://opencode.ai/install" | bash
}

install_zellij() {
    if command -v zellij > /dev/null 2>&1; then
        return
    fi

    echo "[chezmoi] Installing Zellij ${ZELLIJ_VERSION} to ~/.local/bin..."

    case "$(uname -m)" in
        x86_64|amd64) ZELLIJ_ARCH="x86_64-unknown-linux-musl" ;;
        aarch64|arm64) ZELLIJ_ARCH="aarch64-unknown-linux-musl" ;;
        *)
            echo "[chezmoi] Unsupported architecture for Zellij binary: $(uname -m)"
            exit 0
            ;;
    esac

    mkdir -p "$HOME/.local/bin"
    TMPDIR="$(mktemp -d)"
    trap 'rm -rf "$TMPDIR"' EXIT HUP INT TERM

    URL="https://github.com/zellij-org/zellij/releases/download/v${ZELLIJ_VERSION}/zellij-${ZELLIJ_ARCH}.tar.gz"
    if command -v curl > /dev/null 2>&1; then
        curl -fsSL "$URL" -o "$TMPDIR/zellij.tar.gz"
    else
        wget -qO "$TMPDIR/zellij.tar.gz" "$URL"
    fi

    tar -xzf "$TMPDIR/zellij.tar.gz" -C "$TMPDIR"
    install -m 0755 "$TMPDIR/zellij" "$HOME/.local/bin/zellij"
}

run_profile_installers() {
    for installer in $(installer_targets_for_profile); do
        case "$installer" in
            uv)
                install_uv
                ;;
            node)
                install_node
                ;;
            pnpm)
                install_pnpm
                ;;
            kagi-ken-cli)
                install_kagi_ken_cli
                ;;
            opencode)
                install_opencode
                ;;
            zellij)
                install_zellij
                ;;
        esac
    done
}

if command -v apk > /dev/null 2>&1; then
    echo "[chezmoi] Detected Alpine (apk)"
    install_apk_packages "$(repo_packages_for_profile "$APK_SERVER_PACKAGES" "$APK_DEV_PACKAGES" "$APK_AI_PACKAGES")"
elif command -v apt-get > /dev/null 2>&1; then
    echo "[chezmoi] Detected Debian/Ubuntu (apt)"
    install_apt_packages "$(repo_packages_for_profile "$APT_SERVER_PACKAGES" "$APT_DEV_PACKAGES" "$APT_AI_PACKAGES")"
else
    echo "[chezmoi] No supported Linux package manager found"
    exit 1
fi

run_profile_installers

echo "[chezmoi] Linux package installation complete"
{{- end -}}
