{{- includeTemplate ".chezmoitemplates/profile-guard.tmpl" . -}}
{{- if .is_macos -}}
#!/bin/bash

brew analytics off

brew bundle --no-upgrade --file=/dev/stdin <<EOF
brew "ast-grep" # Used by vim
brew "bfs" # Used by fzf & zsh
brew "chezmoi"
brew "coreutils"
brew "curl"
brew "dos2unix"
brew "eza"
brew "fd" # Used by vim
brew "fzf"
brew "gh"
brew "git"
brew "gitui"
brew "go"
brew "htop"
brew "lazygit" # Used by vim
brew "mas"
brew "ncdu"
brew "neovim"
brew "node"
brew "ocrmypdf"
brew "pnpm"
brew "ripgrep"
brew "scrcpy"
brew "ssh-copy-id", link: true
brew "tmux"
brew "tree"
brew "uv"
brew "wget"
brew "yt-dlp"
brew "zellij"
brew "zoxide"
cask "alfred"
cask "balenaetcher"
cask "battery"
cask "beersmith"
cask "bettertouchtool"
cask "brave-browser"
cask "monodraw"
cask "mos"
cask "notion"
cask "obsidian"
cask "parallels"
cask "signal"
cask "syncthing-app"
cask "transmission-remote-gui"
cask "visual-studio-code"
cask "vlc"
cask "ghostty"
cask "wezterm"
cask "whatsapp"
vscode "kilocode.kilo-code"
vscode "ms-vscode.cpptools"
vscode "platformio.platformio-ide"
EOF

if mas account > /dev/null 2>&1; then
  brew bundle --no-upgrade --file=/dev/stdin <<EOF || echo "[chezmoi] Some Mac App Store apps could not be installed; continuing."
mas "Amphetamine", id: 937984704
mas "Bitwarden", id: 1352778147
mas "Brother iPrint&Scan", id: 1193539993
mas "Pixelmator Pro", id: 1289583905
mas "The Unarchiver", id: 425424353
mas "Todoist", id: 585829637
mas "Unsplash Wallpapers", id: 1284863847
mas "WireGuard", id: 1451685025
EOF
else
  echo "[chezmoi] Not signed into the Mac App Store; skipping mas apps."
fi

export PNPM_HOME="${PNPM_HOME:-$HOME/.local/share/pnpm}"
export PNPM_GLOBAL_DIR="${PNPM_GLOBAL_DIR:-$HOME/.local/share/pnpm/global}"
export PATH="$PNPM_HOME:$PATH"
mkdir -p "$PNPM_HOME" "$PNPM_GLOBAL_DIR"

PNPM_CMD="pnpm"
if command -v brew > /dev/null 2>&1; then
  HOMEBREW_PREFIX="$(brew --prefix)"
  if [ -x "$HOMEBREW_PREFIX/bin/pnpm" ]; then
    PNPM_CMD="$HOMEBREW_PREFIX/bin/pnpm"
  fi
fi

KAGI_KEN_CLI_BIN=""
if command -v kagi-ken-cli > /dev/null 2>&1; then
  KAGI_KEN_CLI_BIN="$(command -v kagi-ken-cli)"
fi

case "$KAGI_KEN_CLI_BIN" in
  "$PNPM_HOME"/*) ;;
  *)
    echo "[chezmoi] Installing kagi-ken-cli with pnpm..."
    "$PNPM_CMD" --config.global-bin-dir="$PNPM_HOME" \
      --config.global-dir="$PNPM_GLOBAL_DIR" \
      --config.block-exotic-subdeps=false \
      add --global "github:czottmann/kagi-ken-cli#44b44f2"
    ;;
esac
{{ end -}}
